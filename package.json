{
  "name": "engram-monitor",
  "private": false,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev:engram": "wait-on -t 2000 http://127.0.0.1:7437/health || engram serve",
    "dev:vite": "wait-on http://127.0.0.1:7437/health && vite",
    "dev": "concurrently --kill-others-on-fail -n engram,vite -c blue,green \"npm run dev:engram\" \"npm run dev:vite\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "optimize": "vite optimize",
    "analyze": "vite build --mode production --reportCompressedSize",
    "clean": "node -e \"if (process.platform === 'win32') { require('child_process').execSync('pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/clean.ps1', {stdio: 'inherit'}); } else { require('child_process').execSync('rm -rf dist node_modules pnpm-lock.yaml package-lock.json && npm cache clean --force', {stdio: 'inherit'}); }\"",
    "reinstall": "pnpm run clean && pnpm install",
    "prepare": "lefthook install",
    "biome-all": "biome check --write .",
    "biome-staged": "biome check . --write --staged --verbose",
    "pre-commit": "pnpm run biome-staged && tsc && git add -A"
  },
  "dependencies": {
    "@fontsource-variable/space-grotesk": "5.2.10",
    "@fontsource/geist": "^5.2.8",
    "@fontsource/geist-mono": "^5.2.7",
    "@tanstack/react-query": "5.99.0",
    "axios": "1.15.0",
    "clsx": "2.1.1",
    "lucide-react": "^1.8.0",
    "marked": "18.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router": "7.14.0",
    "react-router-dom": "7.14.0",
    "tailwind-merge": "3.5.0",
    "tailwind-variants": "3.2.2",
    "tw-animate-css": "1.4.0",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitejs/plugin-react-swc": "4.3.0",
    "concurrently": "9.2.1",
    "lefthook": "2.1.5",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vite-plugin-svgr": "5.2.0",
    "vite-tsconfig-paths": "6.1.1",
    "wait-on": "9.0.5"
  }
}
